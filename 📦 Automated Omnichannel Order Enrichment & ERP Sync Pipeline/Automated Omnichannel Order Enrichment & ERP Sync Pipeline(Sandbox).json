      "parameters": {
        "jsCode": "// Generate dynamic mock e-commerce bulk orders\nconst customerTypes = ['B2B', 'B2C'];\nconst domains = ['enterprise.io', 'globaltech.com', 'gmail.com', 'yahoo.com', 'startup.co'];\nconst regions = ['US', 'EU', 'APAC'];\n\nlet mockOrders = [];\n\n// Create a batch of 10 randomized dynamic orders\nfor (let i = 1; i <= 10; i++) {\n  let type = customerTypes[Math.floor(Math.random() * customerTypes.length)];\n  let domain = domains[Math.floor(Math.random() * domains.length)];\n  let region = regions[Math.floor(Math.random() * regions.length)];\n  let subtotal = type === 'B2B' ? Math.floor(Math.random() * 5000) + 1000 : Math.floor(Math.random() * 200) + 15;\n\n  mockOrders.push({\n    order_id: 1000 + i,\n    customer_type: type,\n    email: `buyer_${i}@${domain}`,\n    region: region,\n    subtotal: subtotal,\n    timestamp: new Date().toISOString()\n  });\n}\n\n// Wrap it inside n8n's expected item format\nreturn [{ json: { orders: mockOrders } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
