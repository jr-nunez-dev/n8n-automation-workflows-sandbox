    {
      "parameters": {
        "jsCode": "// 1. Grab all merged items traveling down the pipeline\nconst items = $input.all();\n\n// 2. Loop through each individual order to calculate financials\nfor (let item of items) {\n  let subtotal = item.json.subtotal || 0;\n  let type = item.json.customer_type;\n  \n  // Base tax rate of 10%\n  let taxRate = 0.10; \n  let taxAmount = subtotal * taxRate;\n  \n  // Apply a 5% discount ONLY for B2B orders over $2500\n  let discountAmount = 0;\n  if (type === 'B2B' && subtotal >= 2500) {\n    discountAmount = subtotal * 0.05;\n  }\n  \n  // Run the enterprise formula: Final = Subtotal + Tax - Discount\n  let finalTotal = subtotal + taxAmount - discountAmount;\n  \n  // 3. Append the calculated numbers back onto the item tray\n  item.json.tax_applied = parseFloat(taxAmount.toFixed(2));\n  item.json.discount_applied = parseFloat(discountAmount.toFixed(2));\n  item.json.final_total = parseFloat(finalTotal.toFixed(2));\n}\n\n// 4. Send the enriched orders forward\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
